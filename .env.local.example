# Supabase — get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini — get from: https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=your-gemini-api-key-here

# App secret — any random string, used to protect API routes
APP_SECRET=change-this-to-a-random-secret-string
